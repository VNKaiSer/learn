# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-shared-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp's build directory (https://github.com/nodejs/node-gyp#built-dependencies)
build/Release

# Dependency directories
node_modules/
**/node_modules/
jspm_packages/


# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output directory for build/dist
dist/
build/
out/

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# parcel-cache
.cache
.parcel-cache

# Next.js build images and config
.next
out

# Nuxt.js build and generation
.nuxt
dist

# Gatsby files
.cache/
public/

# vuepress build output
.vuepress/dist

# Serverless Webpack directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Tern project file
.tern-port

# Stores VS Code state
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# IntelliJ files
.idea/

# OS metadata
.DS_Store
Thumbs.db

# TS Compiled outputs (garbage in src directories)
*.js
*.js.map
*.d.ts
*.d.ts.map

# Keep configuration files
!*.config.js
!*.config.mjs
!*.config.ts
!eslint.config.mjs

